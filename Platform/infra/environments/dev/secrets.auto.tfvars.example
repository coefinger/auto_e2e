# Copy to secrets.auto.tfvars (gitignored) and fill in real values.
# These are account-specific / capacity-dependent and must NOT be committed.
#
#   cp secrets.auto.tfvars.example secrets.auto.tfvars
#   # then edit secrets.auto.tfvars with the real ODCR id
#
# Alternatively export TF_VAR_odcr_id=cr-xxxx in your shell / CI.

# On-Demand Capacity Reservation ID for the training GPU node (g6e.4xlarge).
# MUST be created manually per account/AZ (capacity-dependent):
#   aws ec2 create-capacity-reservation \
#     --instance-type g6e.4xlarge \
#     --instance-platform Linux/UNIX \
#     --availability-zone us-west-2b \
#     --instance-count 1 \
#     --instance-match-criteria open
odcr_id = "cr-xxxxxxxxxxxxxxxxx"

# HuggingFace token for gated dataset access (NVIDIA PhysicalAI).
# Obtain via: https://huggingface.co/settings/tokens
hf_token = "hf_xxxxxxxxxxxxxxxxxx"

# ODCR for simulation GPU node (g5.xlarge for CARLA). Optional.
# MUST be created manually per account/AZ (capacity-dependent):
#   aws ec2 create-capacity-reservation \
#     --instance-type g5.xlarge \
#     --instance-platform Linux/UNIX \
#     --availability-zone us-west-2b \
#     --instance-count 1 \
#     --instance-match-criteria open
