# Copy to .env (gitignored) and fill in real values. Source it before running
# platform scripts / terraform:
#
#   cp .env.example .env
#   # edit .env
#   set -a; source .env; set +a
#
# These are account-specific / capacity-dependent and are never committed.

# --- Platform AWS account (EKS / MLOps), profile autowarefoundation ---
export AWS_PROFILE=autowarefoundation
export AWS_REGION=us-west-2
export PLATFORM_ACCOUNT_ID=000000000000        # 12-digit platform account id
export EKS_CLUSTER=auto-e2e-platform

# --- Terraform state backend (created once by bootstrap.sh) ---
export TFSTATE_REGION=us-east-1
export TFSTATE_BUCKET=auto-e2e-platform-tfstate
export TFLOCK_TABLE=auto-e2e-platform-tflock

# --- GPU capacity reservation (changes per provisioning attempt) ---
# terraform reads this as TF_VAR_odcr_id
export TF_VAR_odcr_id=cr-xxxxxxxxxxxxxxxxx

# --- ECR (derived; export for convenience in scripts) ---
export ECR_URL=${PLATFORM_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# --- Dev EC2 account (g6e single box), default profile ---
export DEV_ACCOUNT_ID=000000000000             # 12-digit dev account id
export DEV_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
